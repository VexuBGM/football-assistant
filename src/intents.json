{
  "intents": [
    {
      "tag": "help",
      "patterns": ["^помощ$", "^help$"],
      "responses": [
        "Команди:\n- Добави клуб <име> <град> [година]\n- Покажи всички клубове\n- Изтрий клуб <име|id>\n- помощ\n- изход"
      ]
    },
    {
      "tag": "exit",
      "patterns": ["^изход$", "^exit$", "^quit$"],
      "responses": ["Довиждане!"]
    },
    {
      "tag": "add_club",
      "patterns": [
        "^добави\\s+клуб\\s+(.+?)\\s+(.+?)(?:\\s+(\\d{4}))?$",
        "^add\\s+club\\s+(.+?)\\s+(.+?)(?:\\s+(\\d{4}))?$"
      ],
      "responses": [""]
    },
    {
      "tag": "list_clubs",
      "patterns": ["^покажи\\s+всички\\s+клубове$", "^list\\s+clubs$"],
      "responses": [""]
    },
    {
      "tag": "delete_club",
      "patterns": [
        "^изтрий\\s+клуб\\s+(.+)$",
        "^delete\\s+club\\s+(.+)$"
      ],
      "responses": [""]
    }
  ]
}
