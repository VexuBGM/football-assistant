{
  "intents": [
    {
      "tag": "help",
      "patterns": ["^помощ$", "^help$"]
    },
    {
      "tag": "exit",
      "patterns": ["^изход$", "^exit$", "^quit$"]
    },
    {
      "tag": "add_club",
      "patterns": [
        "^добави\\s+клуб\\s+(.+?)\\s+(.+?)(?:\\s+(\\d{4}))?$",
        "^add\\s+club\\s+(.+?)\\s+(.+?)(?:\\s+(\\d{4}))?$"
      ]
    },
    {
      "tag": "list_clubs",
      "patterns": [
        "^покажи\\s+всички\\s+клубове$",
        "^list\\s+clubs$"
      ]
    },
    {
      "tag": "delete_club",
      "patterns": [
        "^изтрий\\s+клуб\\s+(.+)$",
        "^delete\\s+club\\s+(.+)$"
      ]
    },
    {
      "tag": "add_player",
      "patterns": [
        "^добави\\s+играч\\s+(.+?)\\s+в\\s+(.+?)\\s+позиция\\s+(\\w+)\\s+номер\\s+(\\d+)\\s+роден\\s+(\\S+)\\s+нац(?:ионалност)?\\s+(.+)$",
        "^add\\s+player\\s+(.+?)\\s+in\\s+(.+?)\\s+position\\s+(\\w+)\\s+number\\s+(\\d+)\\s+born\\s+(\\S+)\\s+nat\\s+(.+)$"
      ]
    },
    {
      "tag": "list_players",
      "patterns": [
        "^покажи\\s+играчи\\s+на\\s+(.+)$",
        "^покажи\\s+всички\\s+играчи$",
        "^list\\s+players(?:\\s+of\\s+(.+))?$",
        "^играчи\\s+на\\s+(.+)$",
        "^играчи$"
      ]
    },
    {
      "tag": "update_player_number",
      "patterns": [
        "^смени\\s+номер\\s+на\\s+(.+?)\\s+на\\s+(\\d+)$",
        "^change\\s+number\\s+of\\s+(.+?)\\s+to\\s+(\\d+)$"
      ]
    },
    {
      "tag": "update_player_position",
      "patterns": [
        "^смени\\s+позиция\\s+на\\s+(.+?)\\s+на\\s+(\\w+)$",
        "^change\\s+position\\s+of\\s+(.+?)\\s+to\\s+(\\w+)$"
      ]
    },
    {
      "tag": "update_player_status",
      "patterns": [
        "^смени\\s+статус\\s+на\\s+(.+?)\\s+на\\s+(\\w+)$",
        "^change\\s+status\\s+of\\s+(.+?)\\s+to\\s+(\\w+)$"
      ]
    },
    {
      "tag": "delete_player",
      "patterns": [
        "^изтрий\\s+играч\\s+(.+)$",
        "^delete\\s+player\\s+(.+)$"
      ]
    },
    {
      "tag": "seed_players",
      "patterns": [
        "^зареди\\s+тестови\\s+играчи$",
        "^seed\\s+players$"
      ]
    },
    {
      "tag": "transfer_player",
      "patterns": [
        "^трансфер\\s+(.+?)\\s+от\\s+(.+?)\\s+в\\s+(.+?)\\s+(\\d{4}-\\d{2}-\\d{2})(?:\\s+сума\\s+([0-9]+(?:[.,][0-9]+)?))?$",
        "^трансфер\\s+(.+?)\\s+в\\s+(.+?)\\s+(\\d{4}-\\d{2}-\\d{2})(?:\\s+сума\\s+([0-9]+(?:[.,][0-9]+)?))?$",
        "^transfer\\s+(.+?)\\s+from\\s+(.+?)\\s+to\\s+(.+?)\\s+(\\d{4}-\\d{2}-\\d{2})(?:\\s+fee\\s+([0-9]+(?:[.,][0-9]+)?))?$",
        "^transfer\\s+(.+?)\\s+to\\s+(.+?)\\s+(\\d{4}-\\d{2}-\\d{2})(?:\\s+fee\\s+([0-9]+(?:[.,][0-9]+)?))?$"
      ]
    },
    {
      "tag": "show_transfers_player",
      "patterns": [
        "^покажи\\s+трансфери\\s+на\\s+играч\\s+(.+)$",
        "^show\\s+transfers\\s+of\\s+player\\s+(.+)$",
        "^покажи\\s+трансфери\\s+на\\s+(.+)$",
        "^show\\s+transfers\\s+of\\s+(.+)$"
      ]
    },
    {
      "tag": "show_transfers_club",
      "patterns": [
        "^покажи\\s+трансфери\\s+на\\s+клуб\\s+(.+)$",
        "^show\\s+transfers\\s+of\\s+club\\s+(.+)$"
      ]
    },
    {
      "tag": "seed_transfers",
      "patterns": [
        "^зареди\\s+тестови\\s+трансфери$",
        "^seed\\s+transfers$"
      ]
    }
  ]
}
